[program:assinador-python]
directory=/caminho/real/do/projeto/assinador-python
command=/caminho/real/do/venv/bin/gunicorn -w 4 -b 127.0.0.1:5000 run:app
autostart=true
autorestart=true
startsecs=5
stopwaitsecs=30
user=www-data
redirect_stderr=true
stdout_logfile=/caminho/real/do/projeto/assinador-python/logs/gunicorn.out.log
stdout_logfile_maxbytes=20MB
stdout_logfile_backups=10
environment=PYTHONUNBUFFERED="1"