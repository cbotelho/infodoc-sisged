IMAGE_TAG=1.0.14

APP_PORT=8081
SIGNER_PORT=5000
APP_BASE_URL=http://localhost:8081
PYTHON_SERVICE_PUBLIC_URL=http://localhost:5000
PHP_UPLOAD_MAX_FILESIZE=1024M
PHP_POST_MAX_SIZE=1024M
PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=1200
PHP_MAX_INPUT_TIME=1200
PHP_MAX_INPUT_VARS=5000
PHP_DATE_TIMEZONE=America/Sao_Paulo
PHP_DISPLAY_ERRORS=Off
PHP_LOG_ERRORS=On

DB_SERVER=host.docker.internal
DB_SERVER_PORT=3306
DB_SERVER_USERNAME=root
DB_SERVER_PASSWORD=
DB_DATABASE=infodoc_sisged

DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=infodoc_sisged

SIGNER_SECRET_KEY=troque-esta-chave-docker
TOKEN_EXPIRY=3600

# Cloudflare R2 / S3 compativel
FILE_STORAGE_R2_ENDPOINT=
FILE_STORAGE_R2_REGION=auto
FILE_STORAGE_R2_BUCKET=
FILE_STORAGE_R2_ACCESS_KEY_ID=
FILE_STORAGE_R2_SECRET_ACCESS_KEY=
FILE_STORAGE_R2_OBJECT_PREFIX=
FILE_STORAGE_CRON_INTERVAL=60